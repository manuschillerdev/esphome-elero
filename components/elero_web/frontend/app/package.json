{
  "name": "elero-web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "tsx mock-server.ts & vite",
    "dev:device": "DEVICE_IP=${DEVICE_IP:-192.168.1.100} vite",
    "mock": "tsx mock-server.ts",
    "generate:types": "asyncapi generate models typescript asyncapi.yaml -o src/generated --tsModelType interface --tsEnumType union --tsExportType named --tsIncludeComments --tsRawPropertyNames && ls src/generated/*.ts | grep -v index.ts | sed 's|src/generated/||;s|\\.ts$||' | awk '{print \"export type { \"$1\" } from '\\''./\"$1\"'\\''\" }' > src/generated/index.ts",
    "build": "pnpm generate:types && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@preact/compat": "^17.1.2",
    "@preact/signals": "^2.8.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "preact": "^10.26.5",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@asyncapi/cli": "^6.0.0",
    "@preact/preset-vite": "^2.10.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.3.0",
    "ws": "^8.19.0"
  }
}
